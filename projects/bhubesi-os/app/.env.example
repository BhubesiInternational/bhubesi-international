# Copy this file to .env and fill in real values for your environment.

DATABASE_URL="postgresql://user:password@localhost:5432/bhubesi_os?schema=public"

# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-real-random-secret"

# Optional: set this to enable real Claude-powered AI Workforce replies.
# Without it, the app falls back to a deterministic simulated response
# (see src/lib/responder.ts) so the app still works end to end without a key.
# ANTHROPIC_API_KEY=
